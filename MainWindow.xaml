<Window x:Class="A03_abstraction.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="A03 Data Transfer" Height="320" Width="400">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Source Server -->
        <TextBlock Grid.Row="0" Grid.Column="0"
                   Text="Source Server:"
                   VerticalAlignment="Center" />
        <TextBox x:Name="txtSourceServer"
                 Grid.Row="0" Grid.Column="1"
                 Margin="5" />

        <!-- Source Database -->
        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="Source Database:"
                   VerticalAlignment="Center" />
        <TextBox x:Name="txtSourceDatabase"
                 Grid.Row="1" Grid.Column="1"
                 Margin="5" />

        <!-- Source Table -->
        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="Source Table:"
                   VerticalAlignment="Center" />
        <TextBox x:Name="txtSourceTable"
                 Grid.Row="2" Grid.Column="1"
                 Margin="5" />

        <!-- Show Source Columns Button -->
        <Button x:Name="btnShowSourceColumns"
                Grid.Row="3" Grid.ColumnSpan="2"
                Content="Show Source Columns"
                Margin="5"
                Click="btnShowSourceColumns_Click" />

        <!-- Destination Server -->
        <TextBlock Grid.Row="5" Grid.Column="0"
                   Text="Destination Server:"
                   VerticalAlignment="Center" />
        <TextBox x:Name="txtDestServer"
                 Grid.Row="5" Grid.Column="1"
                 Margin="5" />

        <!-- Destination Database -->
        <TextBlock Grid.Row="6" Grid.Column="0"
                   Text="Destination Database:"
                   VerticalAlignment="Center" />
        <TextBox x:Name="txtDestDatabase"
                 Grid.Row="6" Grid.Column="1"
                 Margin="5" />

        <!-- Destination Table -->
        <TextBlock Grid.Row="7" Grid.Column="0"
                   Text="Destination Table:"
                   VerticalAlignment="Center" />
        <TextBox x:Name="txtDestTable"
                 Grid.Row="7" Grid.Column="1"
                 Margin="5" />

        <!-- Check Source Button -->
        <Button x:Name="btnCheckSource"
                Grid.Row="9" Grid.ColumnSpan="2"
                Content="Check Source"
                Margin="5"
                Click="btnCheckSource_Click" />

        <!-- Result -->
        <TextBlock x:Name="txtResult"
                   Grid.Row="10" Grid.ColumnSpan="2"
                   Margin="5"
                   TextWrapping="Wrap"
                   Foreground="DarkBlue" />
    </Grid>
</Window>
